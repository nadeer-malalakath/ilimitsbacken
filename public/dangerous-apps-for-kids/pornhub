<!-- ══ HERO ══ -->
<header class="hero">
  <div class="hero-glow-a"></div>
  <div class="hero-glow-b"></div>
  <div class="hero-inner">

    <div class="eyebrow">
      <div class="eyebrow-dot"></div>
      iLimits Parental Controls
    </div>

    <h1 class="hero-title">Why This Platform Is<br>Marked as <em>Restricted</em></h1>
    <p class="hero-sub">Understanding why certain platforms may not be suitable for children and how you can take action as a parent.</p>

    <div class="app-card">
      <div class="app-top">
        <div class="app-icon">🔞</div>
        <div>
          <div class="app-name-text">Pornhub</div>
          <div class="app-sub">Adult Content Platform</div>
        </div>
      </div>
      <div class="meta-grid">
        <div class="meta-cell">
          <div class="meta-lbl">Category</div>
