<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Pornhub – Restricted Platform Info · iLimits</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400;1,9..144,600&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --rose:         #F0436A;
    --rose-deep:    #C72E54;
    --rose-light:   #FFF0F4;
    --rose-mid:     #FFCCD8;
    --blush:        #FEF7F9;
    --blush-2:      #FDF2F5;
    --ink:          #19121F;
    --ink-soft:     #35253F;
    --ink-mid:      #6B5879;
    --ink-muted:    #A594B2;
    --border:       #F0E6EC;
    --border-soft:  #F8EEF3;
    --surface:      #FFFFFF;

    /* Brand: slate charcoal — neutral, serious, adult-platform */
    --ph:           #2D3748;
    --ph-mid:       #1A202C;
    --ph-deep:      #0D1117;
    --ph-light:     #F7F8FA;
    --ph-bdr:       #A0AEC0;
    --ph-text:      #0D1117;

    --amber-bg:     #FFFBF0;
    --amber-bdr:    #FDDCB0;
    --amber-text:   #7A3C08;
    --teal-bg:      #F0FDFB;
    --teal-bdr:     #9FEDE0;
    --blue-bg:      #F0F6FF;
    --blue-bdr:     #BFDBFE;
    --peach-bg:     #FFF8F5;
    --peach-bdr:    #FFD4BC;

    --radius-sm:    12px;
    --radius-md:    18px;
    --radius-lg:    26px;
    --shadow-xs:    0 1px 5px rgba(240,67,106,0.07);
    --shadow-sm:    0 2px 14px rgba(240,67,106,0.10);
    --shadow-md:    0 6px 30px rgba(240,67,106,0.13);
    --shadow-lg:    0 14px 52px rgba(240,67,106,0.17);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--blush);
    color: var(--ink);
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -webkit-text-size-adjust: 100%;
  }

  /* ══ HERO ══ */
  .hero {
    background: linear-gradient(158deg, #07080A 0%, #0F1117 50%, #161B22 100%);
    padding: 46px 20px 62px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 65% 52% at 115% 0%,   rgba(45,55,72,0.70) 0%, transparent 55%),
      radial-gradient(ellipse 44% 38% at -8%  96%,  rgba(240,67,106,0.20) 0%, transparent 52%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute; bottom: -2px; left: 0; right: 0;
    height: 36px; background: var(--blush);
    border-radius: 36px 36px 0 0;
  }
  .hero-glow-a {
    position: absolute; top: -72px; right: -72px;
    width: 265px; height: 265px; border-radius: 50%;
    background: radial-gradient(circle, rgba(45,55,72,0.80) 0%, transparent 68%);
    filter: blur(26px); pointer-events: none;
  }
  .hero-glow-b {
    position: absolute; bottom: 28px; left: -56px;
    width: 185px; height: 185px; border-radius: 50%;
    background: radial-gradient(circle, rgba(240,67,106,0.22) 0%, transparent 70%);
    filter: blur(20px); pointer-events: none;
  }
  .hero-inner {
    position: relative; z-index: 1;
    max-width: 480px; margin: 0 auto;
  }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(160,174,192,0.14);
    border: 1px solid rgba(160,174,192,0.26);
    color: #A0AEC0; font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.9px; text-transform: uppercase;
    padding: 5px 13px; border-radius: 100px; margin-bottom: 20px;
  }
  .eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--rose);
    box-shadow: 0 0 0 2px rgba(240,67,106,0.32);
    animation: pdot 2.2s infinite;
  }
  @keyframes pdot {
    0%,100% { box-shadow: 0 0 0 2px rgba(240,67,106,0.32); }
    50%      { box-shadow: 0 0 0 5px rgba(240,67,106,0.10); }
  }

  .hero-title {
    font-family: 'Fraunces', serif;
    font-size: 29px; font-weight: 700;
    color: #fff; line-height: 1.2; letter-spacing: -0.5px;
    margin-bottom: 10px;
  }
  .hero-title em { font-style: italic; color: #FFB3CE; }

  .hero-sub {
    font-size: 13.5px; color: rgba(255,255,255,0.52);
    font-weight: 400; line-height: 1.7; margin-bottom: 28px;
  }

  /* ── App Card ── */
  .app-card {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: var(--radius-lg);
    padding: 18px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }
  .app-top { display: flex; align-items: center; gap: 14px; margin-bottom: 14px; }
  .app-icon {
    width: 58px; height: 58px; border-radius: 16px;
    background: linear-gradient(140deg, #0D1117 0%, #2D3748 55%, #718096 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; flex-shrink: 0;
    box-shadow: 0 4px 22px rgba(45,55,72,0.70), 0 0 0 1px rgba(255,255,255,0.10);
    position: relative; overflow: hidden;
  }
  .app-icon::after {
    content: '';
    position: absolute; top:0; left:0; right:0; height:46%;
    background: rgba(255,255,255,0.10); border-radius: 16px 16px 0 0;
  }
  .app-name-text {
    font-family: 'Fraunces', serif;
    font-size: 20px; font-weight: 700;
    color: #fff; letter-spacing: -0.2px; line-height: 1.2;
  }
  .app-sub {
    font-size: 11.5px; color: rgba(255,255,255,0.42);
    font-weight: 500; margin-top: 4px;
    text-transform: uppercase; letter-spacing: 0.5px;
  }

  .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 10px; }
  .meta-cell {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 11px; padding: 9px 12px;
  }
  .meta-lbl {
    font-size: 9.5px; font-weight: 700; letter-spacing: 0.6px;
    text-transform: uppercase; color: rgba(255,255,255,0.32); margin-bottom: 3px;
  }
  .meta-val { font-size: 12.5px; font-weight: 600; color: #fff; line-height: 1.3; }
  .meta-val.high { color: #FCA5A5; }
  .meta-full {
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.09);
    border-radius: 11px; padding: 9px 12px; margin-bottom: 12px;
  }
  .restricted-flag {
    display: flex; align-items: center; gap: 10px;
    background: rgba(240,67,106,0.16); border: 1px solid rgba(240,67,106,0.28);
    border-radius: 11px; padding: 11px 14px;
  }
  .rf-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--rose); flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(240,67,106,0.28); animation: pdot 2s infinite;
  }
  .rf-title { font-size: 13px; font-weight: 700; color: #FF9DB5; line-height: 1.3; }
  .rf-sub   { font-size: 11px; color: rgba(255,155,181,0.68); font-weight: 400; margin-top: 2px; line-height: 1.4; }

  /* ══ MAIN ══ */
  .main { max-width: 480px; margin: 0 auto; padding: 30px 16px 52px; }

  .sh { margin-bottom: 16px; }
  .sh-pill {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--rose-light); border: 1px solid var(--rose-mid);
    color: var(--rose); font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.7px; text-transform: uppercase;
    padding: 4px 11px; border-radius: 100px; margin-bottom: 9px;
  }
  .sh-title {
    font-family: 'Fraunces', serif; font-size: 21px; font-weight: 700;
    color: var(--ink); letter-spacing: -0.35px; line-height: 1.25;
  }
  .sh-desc { font-size: 13px; color: var(--ink-mid); font-weight: 400; margin-top: 5px; line-height: 1.65; }

  .card {
    background: var(--surface); border-radius: var(--radius-lg);
    border: 1px solid var(--border); box-shadow: var(--shadow-sm);
    overflow: hidden; margin-bottom: 22px;
  }
  .gap { height: 6px; }

  /* ── Platform callout ── */
  .ph-callout {
    display: flex; align-items: flex-start; gap: 12px;
    background: var(--ph-light); border: 1.5px solid var(--ph-bdr);
    border-radius: var(--radius-md); padding: 14px 16px; margin-bottom: 14px;
  }
  .ph-ico {
    width: 38px; height: 38px; border-radius: 11px;
    background: #E2E8F0; border: 1.5px solid var(--ph-bdr);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .ph-title { font-size: 13px; font-weight: 700; color: var(--ph-text); line-height: 1.3; margin-bottom: 3px; }
  .ph-body  { font-size: 12px; color: #1A202C; font-weight: 400; line-height: 1.55; }

  /* ── Feature chips ── */
  .mode-strip {
    display: flex; gap: 8px; margin-bottom: 14px;
    overflow-x: auto; padding-bottom: 2px;
    -webkit-overflow-scrolling: touch; scrollbar-width: none;
  }
  .mode-strip::-webkit-scrollbar { display: none; }
  .mode-chip {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--surface); border: 1.5px solid var(--border);
    border-radius: 100px; padding: 7px 13px;
    font-size: 12px; font-weight: 600; color: var(--ink-mid);
    white-space: nowrap; flex-shrink: 0; box-shadow: var(--shadow-xs);
  }
  .mode-chip .cdot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

  /* ── Section 1 ── */
  .s1-intro {
    padding: 16px 20px 15px;
    font-size: 13.5px; color: var(--ink-mid); font-weight: 400; line-height: 1.72;
    border-bottom: 1px solid var(--border-soft); background: var(--blush-2);
  }
  .s1-intro strong { color: var(--ink); font-weight: 600; }
  .feat-row {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 15px 20px; border-bottom: 1px solid var(--border-soft);
  }
  .feat-row:last-child { border-bottom: none; }
  .feat-ico {
    width: 38px; height: 38px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .feat-name { font-size: 14px; font-weight: 600; color: var(--ink); line-height: 1.3; }
  .feat-desc { font-size: 12px; color: var(--ink-mid); font-weight: 400; margin-top: 3px; line-height: 1.5; }

  /* ── Risk grid ── */
  .risk-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 22px; }
  .risk-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-md); padding: 16px 13px 14px;
    box-shadow: var(--shadow-xs); position: relative; overflow: hidden;
  }
  .risk-card::before {
    content: ''; position: absolute; top:0; left:0; right:0;
    height: 3px; background: var(--rose); border-radius: 3px 3px 0 0;
  }
  .rc-emoji { font-size: 24px; margin-bottom: 9px; display: block; }
  .rc-name  { font-size: 13px; font-weight: 700; color: var(--ink); line-height: 1.3; }
  .rc-desc  { font-size: 11px; color: var(--ink-mid); font-weight: 400; margin-top: 4px; line-height: 1.45; }

  /* ── High risk strip ── */
  .risk-strip {
    display: flex; align-items: center; gap: 12px;
    background: #FFF5F5; border: 1.5px solid #FFBEBE;
    border-radius: var(--radius-md); padding: 14px 16px; margin-bottom: 22px;
  }
  .risk-badge {
    width: 44px; height: 44px; border-radius: 12px;
    background: #FFE4E4; border: 1.5px solid #FFBEBE;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; flex-shrink: 0;
  }
  .risk-strip-text strong { font-size: 13.5px; font-weight: 700; color: #800000; display: block; line-height: 1.3; margin-bottom: 3px; }
  .risk-strip-text span   { font-size: 12px; color: #5C0000; font-weight: 400; line-height: 1.5; }

  /* ── Control note ── */
  .control-note {
    display: flex; align-items: flex-start; gap: 12px;
    background: var(--ph-light); border: 1.5px solid var(--ph-bdr);
    border-radius: var(--radius-md); padding: 14px 16px; margin-bottom: 22px;
  }
  .control-ico {
    width: 38px; height: 38px; border-radius: 11px;
    background: #E2E8F0; border: 1.5px solid var(--ph-bdr);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .control-title { font-size: 13px; font-weight: 700; color: var(--ph-text); line-height: 1.3; margin-bottom: 3px; }
  .control-body  { font-size: 12px; color: #1A202C; font-weight: 400; line-height: 1.55; }

  /* ── Know rows ── */
  .know-row {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 15px 20px; border-bottom: 1px solid var(--border-soft);
  }
  .know-row:last-child { border-bottom: none; }
  .know-num {
    width: 30px; height: 30px; border-radius: 50%;
    background: var(--rose-light); border: 1.5px solid var(--rose-mid);
    color: var(--rose); font-size: 13px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 1px;
  }
  .know-title { font-size: 14px; font-weight: 600; color: var(--ink); line-height: 1.3; }
  .know-body  { font-size: 12px; color: var(--ink-mid); font-weight: 400; margin-top: 4px; line-height: 1.55; }

  /* ── iLimits dark card ── */
  .il-card {
    background: linear-gradient(150deg, #07080A 0%, #0F1117 100%);
    border-radius: var(--radius-lg); padding: 24px 20px 22px;
    margin-bottom: 22px; box-shadow: var(--shadow-lg);
    position: relative; overflow: hidden;
  }
  .il-card::before {
    content: ''; position: absolute; top:-55px; right:-55px;
    width: 200px; height: 200px; border-radius: 50%;
    background: radial-gradient(circle, rgba(45,55,72,0.70) 0%, transparent 68%);
    filter: blur(20px); pointer-events: none;
  }
  .il-card::after {
    content: ''; position: absolute; bottom:-32px; left:-32px;
    width: 135px; height: 135px; border-radius: 50%;
    background: radial-gradient(circle, rgba(240,67,106,0.20) 0%, transparent 70%);
    filter: blur(16px); pointer-events: none;
  }
  .il-eyebrow {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(240,67,106,0.18); border: 1px solid rgba(240,67,106,0.28);
    color: #FF9DB5; font-size: 10px; font-weight: 700;
    letter-spacing: 0.7px; text-transform: uppercase;
    padding: 4px 11px; border-radius: 100px; margin-bottom: 12px; position: relative;
  }
  .il-title {
    font-family: 'Fraunces', serif; font-size: 19px; font-weight: 700; color: #fff;
    line-height: 1.25; margin-bottom: 6px; position: relative;
  }
  .il-desc { font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.65; margin-bottom: 18px; position: relative; }
  .il-rows { position: relative; }
  .il-row {
    display: flex; align-items: center; gap: 12px;
    padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .il-row:last-child { border-bottom: none; padding-bottom: 0; }
  .il-chk {
    width: 26px; height: 26px; border-radius: 8px;
    background: rgba(240,67,106,0.18); border: 1px solid rgba(240,67,106,0.28);
    color: #FF9DB5; font-size: 12px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .il-lbl { font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.82); line-height: 1.4; }

  /* ── Note box ── */
  .note-box {
    background: var(--amber-bg); border: 1.5px solid var(--amber-bdr);
    border-radius: var(--radius-md); padding: 18px 16px 18px 18px;
    margin-bottom: 22px; display: flex; gap: 14px; align-items: flex-start;
  }
  .note-ico {
    width: 42px; height: 42px; border-radius: 13px;
    background: #FEF3C7; border: 1.5px solid var(--amber-bdr);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; flex-shrink: 0;
  }
  .note-title { font-size: 14px; font-weight: 700; color: #7A3C08; line-height: 1.3; margin-bottom: 5px; }
  .note-body  { font-size: 13px; color: var(--amber-text); font-weight: 400; line-height: 1.6; }
  .note-body strong { font-weight: 700; }

  /* ── Tip rows ── */
  .tip-row {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 16px 20px; border-bottom: 1px solid var(--border-soft);
  }
  .tip-row:last-child { border-bottom: none; }
  .tip-ico {
    width: 40px; height: 40px; border-radius: 13px;
    display: flex; align-items: center; justify-content: center;
    font-size: 19px; flex-shrink: 0; border: 1.5px solid var(--border);
  }
  .tip-name { font-size: 14px; font-weight: 600; color: var(--ink); line-height: 1.3; }
  .tip-body  { font-size: 12px; color: var(--ink-mid); font-weight: 400; margin-top: 4px; line-height: 1.55; }

  /* ── Closing ── */
  .closing {
    background: linear-gradient(135deg, #FFF0F4 0%, #FEF3F6 100%);
    border: 1.5px solid var(--rose-mid); border-radius: var(--radius-lg);
    padding: 30px 22px; text-align: center; margin-bottom: 14px;
    box-shadow: var(--shadow-sm); position: relative; overflow: hidden;
  }
  .closing::before {
    content: ''; position: absolute; top:-42px; right:-42px;
    width: 140px; height: 140px; border-radius: 50%;
    background: radial-gradient(circle, rgba(240,67,106,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .closing-emoji { font-size: 46px; margin-bottom: 14px; display: block; position: relative; }
  .closing-title {
    font-family: 'Fraunces', serif; font-size: 19px; font-weight: 700;
    color: var(--rose-deep); margin-bottom: 10px; line-height: 1.25; position: relative;
  }
  .closing-body { font-size: 13px; color: #5A1F35; font-weight: 400; line-height: 1.72; position: relative; }

  /* ── Footer ── */
  .footer { text-align: center; padding: 4px 20px 20px; }
  .footer-brand { display: inline-flex; align-items: center; gap: 7px; margin-bottom: 6px; }
  .f-icon {
    width: 22px; height: 22px; border-radius: 7px;
    background: linear-gradient(135deg, var(--rose) 0%, var(--rose-deep) 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; color: #fff; font-weight: 800;
  }
  .f-name { font-family: 'Fraunces', serif; font-size: 15px; font-weight: 700; color: var(--ink-soft); }
  .footer-txt { font-size: 11px; color: var(--ink-muted); font-weight: 400; line-height: 1.6; }

  /* ── Animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-inner   { animation: fadeUp 0.42s ease both; }
  .card         { animation: fadeUp 0.42s ease 0.04s both; }
  .risk-grid    { animation: fadeUp 0.42s ease 0.06s both; }
  .il-card      { animation: fadeUp 0.42s ease 0.08s both; }
  .note-box     { animation: fadeUp 0.42s ease 0.06s both; }
  .risk-strip   { animation: fadeUp 0.42s ease 0.05s both; }
  .ph-callout   { animation: fadeUp 0.42s ease 0.03s both; }
  .mode-strip   { animation: fadeUp 0.42s ease 0.04s both; }
  .control-note { animation: fadeUp 0.42s ease 0.05s both; }
  .closing      { animation: fadeUp 0.42s ease 0.10s both; }
</style>
</head>
