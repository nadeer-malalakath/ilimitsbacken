{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/verified",
        "destination": "/verified.html"
      },
      {
        "source": "/download",
        "destination": "/download.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}